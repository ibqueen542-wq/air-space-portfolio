import csv from flask import send_file

@app.route("/export_assets/int:user_id") def export_assets(user_id): conn = get_db_connection() cursor = conn.cursor()

cursor.execute(
    "SELECT asset_name, asset_type, value, currency FROM assets WHERE user_id = ?",
    (user_id,)
)

rows = cursor.fetchall()
conn.close()

filename = f"assets_user_{user_id}.csv"

with open(filename, "w", newline="") as file:
    writer = csv.writer(file)
    writer.writerow(["Asset Name", "Type", "Value", "Currency"])

    for row in rows:
        writer.writerow([
            row["asset_name"],
            row["asset_type"],
            row["value"],
            row["currency"]
        ])

return send_file(filename, as_attachment=True)

