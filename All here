REAL-TIME STOCK PRICE API (PORTFOLIO AUTO VALUE)

=====================================================

import requests

NOTE: Replace YOUR_API_KEY with your real key from Alpha Vantage or similar provider

STOCK_API_KEY = "YOUR_API_KEY"

@app.route("/stock_price/<symbol>") def stock_price(symbol): url = f"https://www.alphavantage.co/query?function=GLOBAL_QUOTE&symbol={symbol}&apikey={STOCK_API_KEY}"

try:
    response = requests.get(url)
    data = response.json()

    price = data.get("Global Quote", {}).get("05. price", None)

    if price:
        return jsonify({
            "symbol": symbol,
            "price": float(price),
            "currency": "USD"
        })
    else:
        return jsonify({
            "error": "Stock symbol not found or API limit reached"
        }), 404

except Exception as e:
    return jsonify({
        "error": str(e)
    }), 500

